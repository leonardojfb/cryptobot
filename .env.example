# =============================================
# .env — Bot Autónomo Bybit Paper Trading
# =============================================

# ── Bybit API (Paper Trading Demo) ───────────
# Obtén tus claves en: bybit.com → Perfil → API
# Activa "Demo Trading" en la cuenta primero
BYBIT_API_KEY=TU_API_KEY_AQUI
BYBIT_API_SECRET=TU_API_SECRET_AQUI

# true = Paper Trading (dinero ficticio, gráficas reales)
# false = Dinero real (¡CUIDADO!)
PAPER_TRADING=true

# ── Watchlist fija ────────────────────────────
# Pares que siempre se monitorean
WATCHLIST=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT

# ── Escaneo automático del mercado ────────────
AUTO_SCAN=true
MIN_VOLUME_USDT=5000000     # Volumen mínimo 24h en USDT

# ── Tiempos de ciclo ──────────────────────────
SCAN_INTERVAL_SEC=30        # Cada cuánto escanea buscando oportunidades
MONITOR_INTERVAL_SEC=10     # Cada cuánto revisa posiciones abiertas

# ── Telegram (opcional pero recomendado) ──────
TELEGRAM_BOT_TOKEN=TU_TOKEN_AQUI
TELEGRAM_CHAT_ID=TU_CHAT_ID_AQUI

# ── Parámetros iniciales de riesgo ───────────
# (el bot los ajusta automáticamente aprendiendo)
# DEFAULT_LEVERAGE=10
# RISK_PCT_PER_TRADE=1.0
# MAX_OPEN_POSITIONS=3
